        <mxCell id="terpancung-method-title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=15;fontStyle=1" value="Metode, formula, dan sub-alur penting" vertex="1">
          <mxGeometry x="630" y="120" width="900" height="30" as="geometry" />
        </mxCell>
        <mxCell id="terpancung-method-0" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5e1;strokeColor=#82b366;arcSize=8" value="hitungVolumeTerpancung()&#xa;------------------------------&#xa;luasAtas = super.luas * faktorAtas^2&#xa;volume = (tinggi/3)*(super.luas + luasAtas + sqrt(super.luas*luasAtas))" vertex="1">
