        <mxCell id="limas-method-0" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5e1;strokeColor=#82b366;arcSize=8" value="hitungVolumeLimasElips()&#xa;------------------------------&#xa;volume = (1/3) * super.luas * tinggiLimas" vertex="1">
