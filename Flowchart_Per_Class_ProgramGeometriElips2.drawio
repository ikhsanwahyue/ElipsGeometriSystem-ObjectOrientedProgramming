        <mxCell id="terpancung-method-1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5e1;strokeColor=#82b366;arcSize=8" value="hitungVolumeTerpancung(a,b,h,f)&#xa;------------------------------&#xa;validasi a,b,h,f&#xa;luasAlas = super.hitungLuas(a,b)&#xa;luasAtas = luasAlas * f^2&#xa;volume = (h/3)*(luasAlas + luasAtas + sqrt(luasAlas*luasAtas))" vertex="1">
          <mxGeometry x="1070" y="165" width="390" height="140" as="geometry" />
        </mxCell>
        <mxCell id="terpancung-method-2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5e1;strokeColor=#82b366;arcSize=8" value="hitungLuasPermukaanTerpancung()&#xa;------------------------------&#xa;luasAtas = super.luas * faktorAtas^2&#xa;kelilingAtas = super.keliling * faktorAtas&#xa;selisihA = a - a*faktorAtas&#xa;selisihB = b - b*faktorAtas&#xa;rataGarisPelukis = avg(sqrt(selisihA^2+h^2), sqrt(selisihB^2+h^2))&#xa;luasSelimut = 0.5*(super.keliling+kelilingAtas)*rataGarisPelukis&#xa;luasPermukaan = super.luas + luasAtas + luasSelimut" vertex="1">
          <mxGeometry x="630" y="291" width="390" height="194" as="geometry" />
        </mxCell>
        <mxCell id="terpancung-method-3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5e1;strokeColor=#82b366;arcSize=8" value="hitungLuasPermukaanTerpancung(a,b,h,f)&#xa;------------------------------&#xa;validasi a,b,h,f&#xa;hitung luas/keliling alas dan atas&#xa;hitung garis pelukis dari selisih sumbu&#xa;return luasPermukaanTerpancung" vertex="1">
          <mxGeometry x="1070" y="327" width="390" height="140" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
